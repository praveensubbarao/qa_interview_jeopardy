{
  "name": "qa-interview-jeopardy",
  "version": "1.0.0",
  "description": "AI QE Interview Prep Quiz — question bank manager and quiz server",
  "type": "module",
  "scripts": {
    "start":   "node scripts/stop-port.js && node --env-file-if-exists .env server.js",
    "dev":     "node scripts/stop-port.js && node --env-file-if-exists .env --watch server.js",
    "stop":    "node scripts/stop-port.js",
    "restart": "node scripts/stop-port.js && node --env-file-if-exists .env server.js",
    "build":   "node scripts/build.js",
    "migrate": "node scripts/migrate.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "express": "^4.19.2"
  }
}
